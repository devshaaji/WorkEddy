# WorkEddy Environment Configuration
# Copy this file to .env and fill in your values.

APP_ENV=local

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=workeddy
DB_USER=workeddy
DB_PASS=workeddy
DB_ROOT_PASS=rootsecret

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
WORKER_QUEUE=scan_jobs

# JWT
JWT_SECRET=change-me-in-production
JWT_TTL_SECONDS=3600

# Uploads
MAX_VIDEO_UPLOAD_BYTES=209715200

# Rate Limiting
RATE_LIMIT_RPM=120

# Video Data Retention (days before raw video files are deleted; 0 = keep forever)
VIDEO_RETENTION_DAYS=30
